#!/bin/bash
export DISPLAY=:0

# Disable screen blanking
xset s off
xset -dpms
xset s noblank

# Ctrl+Alt+Backspace to exit X
setxkbmap -option terminate:ctrl_alt_bksp

# Hide mouse cursor
unclutter &

# Wait for X to be ready
sleep 5

# Suppress Chromium "unclean exit" warnings
sed -i 's/"exited_cleanly":false/"exited_cleanly":true/' ~/.config/chromium/'Local State'
sed -i 's/"exited_cleanly":false/"exited_cleanly":true/; s/"exit_type":"[^"]\+"/"exit_type":"Normal"/' ~/.config/chromium/Default/Preferences

# Detect Chromium major version and choose the right hardware video decode flag
# - Chromium 109+: V4L2StatelessVideoDecoder (newer, preferred on Pi 4)
# - Chromium 91-108: V4L2StatefulVideoDecoder (older stateful API)
# - Older/unknown: VaapiVideoDecoder (fallback, won't help on Pi but won't break)
CHROMIUM_VERSION=$(chromium --version 2>/dev/null | grep -oP '\d+' | head -1)

if [ -n "$CHROMIUM_VERSION" ]; then
  if [ "$CHROMIUM_VERSION" -ge 109 ]; then
    VIDEO_DECODE_FLAG="V4L2StatelessVideoDecoder"
  elif [ "$CHROMIUM_VERSION" -ge 91 ]; then
    VIDEO_DECODE_FLAG="V4L2StatefulVideoDecoder"
  else
    VIDEO_DECODE_FLAG="VaapiVideoDecoder"
  fi
else
  VIDEO_DECODE_FLAG="V4L2StatelessVideoDecoder"
fi

echo "Chromium version: ${CHROMIUM_VERSION:-unknown}, using decode flag: $VIDEO_DECODE_FLAG"

# Launch Chromium in kiosk mode with hardware-accelerated video decode
chromium \
  --use-gl=egl \
  --enable-features=$VIDEO_DECODE_FLAG \
  --enable-accelerated-video-decode \
  --ignore-gpu-blocklist \
  --enable-gpu-rasterization \
  --disable-features=UseChromeOSDirectVideoDecoder \
  --hide-scrollbars \
  --noerrdialogs \
  --kiosk http://localhost:4000/viewer \
  --incognito \
  --disable-translate \
  --no-first-run &
